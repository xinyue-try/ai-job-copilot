page {
  background: #f7f3f5;
  color: #241923;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  font-size: 28rpx;
}

.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 56rpx;
  box-sizing: border-box;
}

.page-title {
  font-size: 46rpx;
  line-height: 1.15;
  font-weight: 800;
  margin: 24rpx 0 12rpx;
}

.page-subtitle {
  color: #695f69;
  line-height: 1.55;
  margin-bottom: 28rpx;
}

.card {
  background: #fff;
  border: 1rpx solid #e2c9d0;
  border-radius: 16rpx;
  padding: 24rpx;
  box-sizing: border-box;
  margin-bottom: 20rpx;
}

.soft-card {
  background: #fbf7f8;
}

.section-title {
  font-size: 32rpx;
  font-weight: 800;
  margin: 24rpx 0 16rpx;
}

.kicker {
  color: #852344;
  font-size: 22rpx;
  font-weight: 800;
  margin-bottom: 8rpx;
}

.muted {
  color: #746b74;
  font-size: 24rpx;
  line-height: 1.55;
}

.primary-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 14rpx;
  background: #852344;
  color: #fff;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 22rpx rgba(133, 35, 68, 0.22);
}

.secondary-btn {
  height: 72rpx;
  border: 1rpx solid #d9b9c3;
  border-radius: 14rpx;
  background: #fff;
  color: #852344;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 22rpx;
}

.input,
.textarea,
.picker-line {
  width: 100%;
  min-height: 78rpx;
  border: 1rpx solid #d9b9c3;
  border-radius: 12rpx;
  background: #fff;
  padding: 0 22rpx;
  box-sizing: border-box;
  color: #241923;
}

.textarea {
  min-height: 220rpx;
  padding: 22rpx;
  line-height: 1.55;
}

.field-label {
  display: block;
  color: #403643;
  font-size: 24rpx;
  font-weight: 700;
  margin: 20rpx 0 10rpx;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.chip {
  border: 1rpx solid #d9b9c3;
  border-radius: 999rpx;
  background: #fff;
  color: #403643;
  padding: 14rpx 22rpx;
  font-size: 24rpx;
}

.chip.active {
  color: #852344;
  background: #f8dce5;
  border-color: #852344;
  font-weight: 800;
}

.split {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.result-score {
  font-size: 58rpx;
  font-weight: 900;
  color: #852344;
  line-height: 1;
}

.tag {
  display: inline-block;
  background: #f7e6ec;
  color: #852344;
  border-radius: 999rpx;
  padding: 8rpx 14rpx;
  font-size: 22rpx;
  margin: 6rpx 8rpx 0 0;
}

.list-item {
  color: #3a3039;
  line-height: 1.65;
  margin: 10rpx 0;
}

.danger {
  color: #b42318;
}

.sticky-bottom {
  position: sticky;
  bottom: 20rpx;
  z-index: 2;
}
