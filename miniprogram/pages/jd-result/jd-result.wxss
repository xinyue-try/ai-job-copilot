.job-title {
  font-size: 36rpx;
  font-weight: 900;
  margin-bottom: 8rpx;
}

.score-row {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-top: 26rpx;
}

.action-pill {
  background: #852344;
  color: #fff;
  border-radius: 999rpx;
  padding: 14rpx 22rpx;
  font-weight: 800;
}

.section-mini {
  font-weight: 900;
  margin-bottom: 14rpx;
}

.section-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.section-header .section-mini {
  margin-bottom: 0;
}

.section-hint {
  color: #8a7f89;
  font-size: 22rpx;
  line-height: 1.4;
}

.qa-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  border: 1rpx solid #ead7dd;
  border-left: 6rpx solid #852344;
  border-radius: 12rpx;
  padding: 18rpx 20rpx 18rpx 18rpx;
  margin: 12rpx 0;
  background: #fff;
}

.qa-content {
  flex: 1;
}

.qa-question {
  font-weight: 800;
  margin-bottom: 8rpx;
}

.qa-arrow {
  color: #852344;
  font-size: 42rpx;
  line-height: 1;
  font-weight: 300;
}

.prepare-card {
  background: #fbf7f8;
}

.prepare-btn {
  margin-top: 20rpx;
}

.prep-block {
  border-top: 1rpx solid #ead7dd;
  padding-top: 18rpx;
  margin-top: 18rpx;
}

.prep-block:first-of-type {
  border-top: 0;
  padding-top: 0;
  margin-top: 0;
}

.prep-title {
  color: #241923;
  font-weight: 900;
  margin-bottom: 12rpx;
}

.star-row {
  display: flex;
  gap: 14rpx;
  align-items: flex-start;
  margin-top: 12rpx;
}

.star-label {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: #852344;
  color: #fff;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.star-text {
  flex: 1;
}

.prep-question {
  position: relative;
  border: 1rpx solid #ead7dd;
  border-radius: 12rpx;
  padding: 18rpx 50rpx 18rpx 18rpx;
  margin-top: 14rpx;
  background: #fff;
}

.prep-question-title {
  color: #241923;
  font-weight: 800;
  line-height: 1.5;
  margin-bottom: 8rpx;
}

.prep-arrow {
  position: absolute;
  right: 18rpx;
  top: 50%;
  transform: translateY(-50%);
  color: #852344;
  font-size: 42rpx;
  line-height: 1;
  font-weight: 300;
}

.copy-btn {
  margin-top: 18rpx;
}
