<view class="page">
  <view class="card">
    <view class="kicker">{{job.company || "未识别公司"}}</view>
    <view class="job-title">{{job.title || "未识别岗位"}}</view>
    <view class="muted">{{job.city || "城市未识别"}} · {{job.salary || "薪资未识别"}}</view>
    <view class="score-row">
      <view>
        <view class="result-score">{{score}}</view>
        <view class="muted">匹配分</view>
      </view>
      <view class="action-pill">{{action}}</view>
    </view>
  </view>

  <view class="card">
    <view class="section-mini">主要匹配点</view>
    <view class="list-item" wx:for="{{matchReasons}}" wx:key="*this">• {{item}}</view>
  </view>

  <view class="card">
    <view class="section-mini danger">主要风险点</view>
    <view class="list-item" wx:for="{{risks}}" wx:key="*this">× {{item}}</view>
  </view>

  <view class="card">
    <view class="section-mini">高风险面试雷达</view>
    <view class="qa-card" wx:for="{{radar}}" wx:key="question" bindtap="prepareRadarQuestion" data-question="{{item.question}}">
      <view class="qa-content">
        <view class="qa-question">{{item.numberText}} {{item.question}}</view>
        <view class="muted">策略：{{item.answerStrategy}}</view>
      </view>
      <view class="qa-arrow">›</view>
    </view>
  </view>

  <view class="card prepare-card">
    <view class="section-mini">求职记忆准备</view>
    <view class="muted">结合你的求职记忆，生成这一轮面试的准备重点和 STAR 回答提醒。</view>
    <view class="primary-btn prepare-btn" bindtap="prepareWithMemory">{{prepareButtonText}}</view>
  </view>

  <view class="card" wx:if="{{preparation}}">
    <view class="section-header">
      <view class="section-mini">本轮准备方案</view>
      <view class="section-hint">{{memoryStatusText}}</view>
    </view>

    <view class="prep-block">
      <view class="prep-title">本次参考记忆</view>
      <view wx:if="{{!preparation.memories.length}}" class="muted">先添加一条项目经历、回答素材或失败问题，后续准备会自动召回。</view>
      <view class="memory-item" wx:for="{{preparation.memories}}" wx:key="id">
        <view class="memory-title">{{item.title}}</view>
        <view class="muted memory-meta">{{item.metaLine}}</view>
        <view class="muted memory-summary">{{item.summary}}</view>
        <view wx:if="{{item.tags.length}}">
          <text class="tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
        </view>
      </view>
    </view>

    <view class="prep-block">
      <view class="prep-title">本轮重点</view>
      <view class="muted">{{preparation.roundFocus}}</view>
    </view>

    <view class="prep-block">
      <view class="prep-title">STAR 回答法</view>
      <view class="star-row" wx:for="{{preparation.starTips}}" wx:key="id">
        <view class="star-label">{{item.label}}</view>
        <view class="muted star-text">{{item.text}}</view>
      </view>
    </view>

    <view class="prep-block" wx:if="{{preparation.risks.length}}">
      <view class="prep-title danger">历史风险</view>
      <view class="list-item" wx:for="{{preparation.risks}}" wx:key="id">× {{item.text}}</view>
    </view>

    <view class="prep-block" wx:if="{{preparation.likelyQuestions.length}}">
      <view class="prep-title">可能问题</view>
      <view class="prep-question" wx:for="{{preparation.likelyQuestions}}" wx:key="id" bindtap="prepareLikelyQuestion" data-question="{{item.question}}">
        <view class="prep-question-title">{{item.numberText}} {{item.question}}</view>
        <view class="muted" wx:if="{{item.why}}">{{item.why}}</view>
        <view class="muted" wx:if="{{item.strategy}}">{{item.strategy}}</view>
        <view class="muted" wx:if="{{item.evidence}}">{{item.evidence}}</view>
        <view class="prep-arrow">›</view>
      </view>
    </view>

    <view class="prep-block" wx:if="{{preparation.plan.length}}">
      <view class="prep-title">练习计划</view>
      <view class="list-item" wx:for="{{preparation.plan}}" wx:key="id">• {{item.text}}</view>
    </view>

    <view class="prep-block">
      <view class="prep-title">一分钟 Pitch</view>
      <view class="muted">{{preparation.pitch}}</view>
    </view>
  </view>

  <view class="card">
    <view class="section-mini">打招呼语</view>
    <view class="muted">{{greeting}}</view>
    <view class="secondary-btn copy-btn" bindtap="copyGreeting">复制</view>
  </view>
</view>
