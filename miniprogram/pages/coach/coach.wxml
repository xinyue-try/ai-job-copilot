<view class="page">
  <view class="page-title">问一问 AI</view>
  <view class="page-subtitle">不知道怎么回答时，输入问题，AI 会结合 JD、简历和求职记忆生成回答思路。</view>

  <textarea class="textarea question-box" maxlength="500" value="{{question}}" bindinput="onQuestionInput" placeholder="输入或粘贴你遇到的面试难题..." />

  <view class="section-title">推荐提问</view>
  <view class="chip-row">
    <view class="chip" wx:for="{{suggestions}}" wx:key="*this" bindtap="useSuggestion" data-text="{{item}}">{{item}}</view>
  </view>

  <view class="card">
    <view class="field-label">面试轮次</view>
    <view class="chip-row">
      <view class="chip {{round === item ? 'active' : ''}}" wx:for="{{rounds}}" wx:key="*this" bindtap="selectRound" data-value="{{item}}">{{item}}</view>
    </view>
    <view class="field-label">回答时长</view>
    <view class="chip-row">
      <view class="chip {{timeLimit === item ? 'active' : ''}}" wx:for="{{times}}" wx:key="*this" bindtap="selectTime" data-value="{{item}}">{{item}}</view>
    </view>
    <view class="field-label">回答风格</view>
    <view class="chip-row">
      <view class="chip {{style === item ? 'active' : ''}}" wx:for="{{styles}}" wx:key="*this" bindtap="selectStyle" data-value="{{item}}">{{item}}</view>
    </view>
  </view>

  <view class="sticky-bottom">
    <view class="primary-btn" bindtap="ask">生成回答思路</view>
  </view>
</view>
