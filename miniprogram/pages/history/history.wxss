.history-card {
  overflow: hidden;
}

.history-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.history-main {
  flex: 1;
  min-width: 0;
}

.history-actions {
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex-shrink: 0;
}

.delete-btn {
  border: 1rpx solid #f0c7c2;
  border-radius: 999rpx;
  color: #b42318;
  background: #fff7f7;
  font-size: 22rpx;
  font-weight: 800;
  padding: 8rpx 14rpx;
  line-height: 1;
}

.history-title {
  font-weight: 900;
  font-size: 30rpx;
  margin-bottom: 8rpx;
  line-height: 1.4;
}

.history-arrow {
  color: #852344;
  font-size: 42rpx;
  line-height: 1;
  transform: rotate(0deg);
}

.history-arrow.open {
  transform: rotate(90deg);
}

.summary {
  margin: 18rpx 0 10rpx;
}

.history-detail {
  border-top: 1rpx solid #ead7dd;
  margin-top: 22rpx;
  padding-top: 20rpx;
}

.detail-section {
  margin-top: 20rpx;
}

.detail-section:first-child {
  margin-top: 0;
}

.detail-title {
  color: #241923;
  font-weight: 900;
  margin-bottom: 12rpx;
}

.question-card {
  background: #fbf7f8;
  border: 1rpx solid #ead7dd;
  border-radius: 12rpx;
  padding: 18rpx;
  margin-top: 14rpx;
}

.question-title {
  display: flex;
  gap: 8rpx;
  color: #241923;
  font-weight: 800;
  line-height: 1.5;
  margin-bottom: 10rpx;
}

.detail-line {
  margin-top: 6rpx;
}

.danger-text {
  color: #b42318;
}

.evidence-item {
  color: #3a3039;
  line-height: 1.6;
  margin: 8rpx 0;
}

.empty-detail {
  text-align: center;
  padding: 24rpx 0 4rpx;
}

.empty-state {
  color: #746b74;
  text-align: center;
  padding: 120rpx 0;
}
