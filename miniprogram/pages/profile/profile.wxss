.section-mini {
  font-weight: 900;
  margin-bottom: 14rpx;
}

.env-pill {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
  margin-bottom: 12rpx;
}

.env-pill.ok {
  color: #0f5f43;
  background: #dff5eb;
}

.env-pill.warn {
  color: #8a3d05;
  background: #fff0d8;
}

.status-card {
  background: #fbf7f8;
}

.status-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.refresh-btn {
  width: 128rpx;
  height: 64rpx;
  flex-shrink: 0;
}

.clear-btn {
  margin-top: 18rpx;
}

.status-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  border-top: 1rpx solid #ead7dd;
  padding-top: 18rpx;
  margin-top: 18rpx;
}

.status-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #b42318;
  margin-top: 10rpx;
  flex-shrink: 0;
}

.status-dot.ok {
  background: #0f7a55;
}

.status-content {
  flex: 1;
  min-width: 0;
}

.status-label {
  color: #241923;
  font-weight: 800;
  margin-bottom: 4rpx;
}

.status-tip {
  border-top: 1rpx solid #ead7dd;
  margin-top: 18rpx;
  padding-top: 18rpx;
}

.resume-text {
  min-height: 420rpx;
}

.input-meta {
  color: #8f7f87;
  font-size: 24rpx;
  line-height: 1.5;
  margin-top: 12rpx;
}

.save-btn {
  margin-top: 20rpx;
}

.memory-btn {
  margin-top: 18rpx;
}
