<view class="page">
  <view class="page-title">{{pageTitle}}</view>
  <view class="page-subtitle">{{pageSubtitle}}</view>

  <view class="card">
    <view class="field-label">记忆类型</view>
    <view class="chip-row">
      <view class="chip {{type === item.value ? 'active' : ''}}" wx:for="{{memoryTypes}}" wx:key="value" bindtap="selectType" data-value="{{item.value}}">{{item.label}}</view>
    </view>
  </view>

  <view class="card">
    <view class="field-label">公司/组织（可选）</view>
    <input class="input" value="{{company}}" bindinput="onCompany" placeholder="例如：字节跳动 / B站 / Mock 面试" />
    <view class="field-label">岗位/方向（可选）</view>
    <input class="input" value="{{role}}" bindinput="onRole" placeholder="例如：AI 产品经理 / 增长产品 / 项目介绍" />

    <block wx:if="{{type === 'interview_review'}}">
      <view class="field-label">面试轮次</view>
      <view class="chip-row">
        <view class="chip {{round === item ? 'active' : ''}}" wx:for="{{rounds}}" wx:key="*this" bindtap="selectRound" data-value="{{item}}">{{item}}</view>
      </view>

      <view class="field-label">当前结果</view>
      <view class="chip-row">
        <view class="chip {{result === item ? 'active' : ''}}" wx:for="{{results}}" wx:key="*this" bindtap="selectResult" data-value="{{item}}">{{item}}</view>
      </view>
    </block>
  </view>

  <view class="field-label row-label">
    <text>{{contentLabel}}</text>
    <text class="muted">{{contentMeta}} · {{rawTextLength}} 字</text>
  </view>
  <textarea class="textarea review-text" maxlength="-1" value="{{rawText}}" bindinput="onRawText" placeholder="{{contentPlaceholder}}" />
  <view class="muted review-tip">{{contentTip}}</view>

  <view class="sticky-bottom">
    <view class="primary-btn" bindtap="save">保存到求职记忆</view>
  </view>

  <view class="section-title" wx:if="{{structured.title}}">实时结构化分析</view>
  <view class="card" wx:if="{{structured.title}}">
    <view class="section-mini">可复用问题</view>
    <view class="list-item" wx:for="{{structured.questions}}" wx:key="question">• {{item.question}}</view>
  </view>
  <view class="card" wx:if="{{structured.summary}}">
    <view class="section-mini">记忆摘要</view>
    <view class="muted">{{structured.summary}}</view>
  </view>
  <view class="card" wx:if="{{structured.tags.length}}">
    <view class="section-mini">标签</view>
    <view class="tag" wx:for="{{structured.tags}}" wx:key="*this">{{item}}</view>
  </view>
</view>
