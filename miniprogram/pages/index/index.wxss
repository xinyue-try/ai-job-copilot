.brand {
  padding: 10rpx 0 8rpx;
}

.main-action {
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-color: #d9b9c3;
}

.action-title {
  color: #852344;
  font-size: 36rpx;
  font-weight: 900;
  margin-bottom: 8rpx;
}

.arrow {
  color: #852344;
  font-size: 56rpx;
}

.mini-action {
  min-height: 170rpx;
}

.mini-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 14rpx;
  background: #f7e6ec;
  color: #852344;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 900;
  margin-bottom: 16rpx;
}

.mini-title {
  font-weight: 900;
  margin-bottom: 6rpx;
}

.mini-desc {
  color: #695f69;
  font-size: 23rpx;
}

.recent-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 10rpx 0;
  color: #403643;
}

.pill {
  color: #852344;
  font-size: 22rpx;
  background: #f7e6ec;
  border-radius: 999rpx;
  padding: 8rpx 14rpx;
}
