.resume-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.resume-name {
  font-size: 30rpx;
  font-weight: 800;
  margin-top: 6rpx;
}

.small-btn {
  min-width: 112rpx;
  height: 64rpx;
}

.upload-card {
  height: 310rpx;
  border: 2rpx dashed #d9b9c3;
  border-radius: 16rpx;
  background: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
}

.upload-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #f1e6ea;
  color: #852344;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
  margin-bottom: 18rpx;
}

.upload-title {
  font-weight: 900;
  margin-bottom: 8rpx;
}

.divider {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #857985;
  margin: 20rpx 0;
}

.recent {
  display: flex;
  justify-content: space-between;
  color: #403643;
}
